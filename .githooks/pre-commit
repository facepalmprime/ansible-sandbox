#!/usr/bin/env bash
# Runs ansible-lint before every commit.
# A lint failure blocks the commit - fix the violation, then commit again.

set -e

echo "Running ansible-lint..."

staged_files=$(git diff --staged --name-only --diff-filter=ACMR -- '*.yml' '*.yaml')
if [ -n "$staged_files" ]; then
  ansible-lint $staged_files
else
  echo "No YAML file staged, skipping ansible-lint."
fi

echo "ansible-lint passed."

echo "Running gitleaks secret scan..."
gitleaks protect --staged --redact

echo "gitleaks passed"
