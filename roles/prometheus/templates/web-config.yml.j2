tls_server_config:
  cert_file: {{ prometheus_tls_cert }}
  key_file: {{ prometheus_tls_key }}
  min_version: TLS12
  cipher_suites:
    - TLS_ECDHE_ECDSA_WITH_AES_128_GCM_SHA256
    - TLS_ECDHE_RSA_WITH_AES_128_GCM_SHA256
    - TLS_ECDHE_ECDSA_WITH_AES_256_GCM_SHA384
    - TLS_ECDHE_RSA_WITH_AES_256_GCM_SHA384

basic_auth_users:
  {{ prometheus_basic_auth_user }}: {{ vault_prometheus_basic_auth_password_hash }}
