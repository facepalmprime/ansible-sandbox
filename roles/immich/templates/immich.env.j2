# Immich environment - managed by Ansible, do not edit manually
DB_HOSTNAME=database
DB_USERNAME={{ vault_immich_db_user }}
DB_PASSWORD={{ vault_immich_db_password }}
DB_DATABASE_NAME=immich
REDIS_HOSTNAME=redis
UPLOAD_LOCATION={{ immich_upload_dir }}
