# PostgresSQL container initialisation vars
POSTGRES_PASSWORD={{ vault_immich_db_password }}
POSTGRES_USER={{ vault_immich_db_user }}
POSTGRES_DB=immich
POSTGRES_INITDB_ARGS=--data-checksums
