# Nextcloud nginx vhost - managed by Ansible, do not edit manually

# HTTP -> HTTPS redirect
server {
    listen 80;
    server_name {{ ansible_default_ipv4.address }} {{ inventory_hostname }};
    return 301 https://$host$request_uri;
}

server {
    listen {{ nextcloud_nginx_port }} ssl;
    server_name {{ ansible_default_ipv4.address }} {{ inventory_hostname }};

    ssl_certificate {{ nextcloud_tls_cert }};
    ssl_certificate_key {{ nextcloud_tls_key }};
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_ciphers HIGH:!aNULL:!MD5;
    ssl_prefer_server_ciphers on;
    ssl_session_cache shared:NC_SSL:10m;
    ssl_session_timeout 10m;

    # Security headers - OWASP ASVS level 1 + Nextcloud security scan requirments
    add_header Referrer-Policy "no-referrer" always;
    add_header Strict-Transport-Security "max-age=15552000; includeSubDomains" always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header X-Frame-Options "SAMEORIGIN" always;
    add_header X-XSS-Protection "1; mode=block" always;
    add_header Permissions-Policy "interest-cohort=()" always;

    # Large file support - required for video and archive uploads
    client_max_body_size {{ nextcloud_upload_max_size }};
    client_body_timeout 3600s;
    send_timeout 3600s;

    root {{ nextcloud_web_root }};
    index index.php index.html;

    # Nextcloud required: CalDAV/CardDAV autodiscovery redirects
    location /.well-known/carddav { return 301 /remote.php/dav; }
    location /.well-known/caldav { return 301 /remote.php/dav; }
    location /.well-known/ { try_files $uri $uri/ =404; }

    # Block direct access to Nextcloud internals
    location ~ ^/(?:build|tests|config|lib|3rdparty|templates|data)/ { deny all; }
    location ~ ^/(?:\.|autotest|occ|issue|indie|db_|console) { deny all; }

    # PHP - FastCGI to PHP-FPM unix socket
    location ~ \.php(?:$|/) {
        fastcgi_split_path_info ^(.+?\.php)(/.*)$;
        set $path_info $fastcgi_path_info;
        fastcgi_param PATH_INFO $path_info;

        fastcgi_pass unix:{{ nextcloud_fpm_socket }};
        fastcgi_index index.php;
        fastcgi_read_timeout 3600s;

        include fastcgi_params;
        fastcgi_param SCRIPT_FILENAME $document_root$fastcgi_script_name;
        fastcgi_param HTTPS on;

        fastcgi_hide_header X-Powered-By;
    }
    # Static file caching
    location ~* \.(?:css|js|svg|gif|png|jpg|ico|woff2?)$ {
        try_files $uri /index.php$request_uri;
        expires 6M;
        access_log off;
    }

    location / {
        try_files $uri /index.php$request_uri;
    }
}
