; Nextcloud PHP-FPM pool - managed by Ansible, do not edit manually
[nextcloud]
user = nextcloud
group = nextcloud

; Unix socket - nginx communicates via socket (faster than TCP, no port exposure)
listen = {{ nextcloud_fpm_socket }}
listen.owner = nginx
listen.group = nginx
listen.mode = 0660

; Process management - dynamic, tuned for a dedicated node
pm = dynamic
pm.max_children = {{ nextcloud_fpm_max_children }}
pm.start_servers = {{ nextcloud_fpm_start_servers }}
pm.min_spare_servers = {{ nextcloud_fpm_min_spare }}
pm.max_spare_servers = {{ nextcloud_fpm_max_spare}}
pm.max_requests = 500

; Dedicated session storage - not shared with other PHP apps on this node
php_value[session.save_handler] = files
php_value[session.save_path] = {{ nextcloud_session_dir }}

; Upload limits - large file support (video uploads, archives)
php_value[upload_max_filesize] = {{ nextcloud_upload_max_size }}
php_value[post_max_size] = {{ nextcloud_upload_max_size }}
php_value[max_execution_time] = 3600
php_value[max_input_time] = 3600
php_value[memory_limit] = 512M

; Environment - required for occ CLI to function via PHP-FPM context
env[HOSTNAME] = $HOSTNAME
env[PATH] = /usr/local/bin:/usr/bin:/bin
env[TMP] = /tmp
env[TMPDIR] = /tmp
env[TEMP] = /tmp
